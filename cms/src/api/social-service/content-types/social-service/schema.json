{
    "kind": "collectionType",
    "collectionName": "social_services",
    "info": {
        "singularName": "social-service",
        "pluralName": "social-services",
        "displayName": "Social Service",
        "description": "Social media growth services"
    },
    "options": {
        "draftAndPublish": true
    },
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "slug": {
            "type": "uid",
            "targetField": "name",
            "required": true
        },
        "bullets": {
            "type": "component",
            "repeatable": true,
            "component": "shared.bullet"
        },
        "startingPrice": {
            "type": "decimal"
        },
        "currency": {
            "type": "string",
            "default": "VND"
        },
        "image": {
            "type": "media",
            "multiple": false,
            "allowedTypes": [
                "images"
            ]
        },
        "isActive": {
            "type": "boolean",
            "default": true
        },
        "sortOrder": {
            "type": "integer",
            "default": 0
        }
    }
}