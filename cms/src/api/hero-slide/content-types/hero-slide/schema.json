        "subtitle": {
            "type": "string"
        },
        "buttonText": {
            "type": "string",
            "default": "Xem chi tiết"
        },
        "buttonHref": {
            "type": "string",
            "default": "/#premium"
        },
        "bgImage": {
            "type": "media",
            "multiple": false,
            "required": true,
            "allowedTypes": [
                "images"
            ]
        },
        "order": {
            "type": "integer",
            "default": 0
        },
        "isActive": {
            "type": "boolean",
            "default": true
