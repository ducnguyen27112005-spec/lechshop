# ===========================================
# NextAuth (REQUIRED)
# ===========================================
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-secure-random-string

# Your production domain
NEXTAUTH_URL=https://www.lecshop.com

# ===========================================
# Admin Credentials (env-based fallback)
# Used when database is unavailable (e.g. Vercel serverless with SQLite)
# ===========================================
ADMIN_USERNAME=admin@lechshop.vn
ADMIN_PASSWORD=change-me-to-a-secure-password

# ===========================================
# Database (SQLite default, only works on VPS)
# ===========================================
# DATABASE_URL=file:./prisma/dev.db
