generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PremiumProduct {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  thumbnail        String?
  shortDescription String?
  benefits         String?
  price            Float
  durationDays     Int
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

enum SocialPlatform {
  TIKTOK
  FACEBOOK
  INSTAGRAM
}

enum ServiceType {
  FOLLOW
  LIKE
  VIEW
}

model SocialService {
  id            String         @id @default(cuid())
  platform      SocialPlatform
  serviceType   ServiceType
  name          String
  min           Int
  max           Int
  pricePerUnit  Float
  warrantyDays  Int
  note          String?
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

enum OrderType {
  PREMIUM
  SOCIAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillStatus {
  NEW
  PROCESSING
  DONE
  CANCELLED
}

model Order {
  id             String        @id @default(cuid())
  code           String        @unique
  customerName   String
  customerEmail  String
  type           OrderType
  amount         Float
  paymentStatus  PaymentStatus @default(PENDING)
  fulfillStatus  FulfillStatus @default(NEW)
  adminNote      String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

enum PostStatus {
  DRAFT
  PUBLISHED
}

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String
  thumbnail   String?
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id         String   @id @default("site-settings")
  hotline    String?
  email      String?
  address    String?
  socialLinks Json?
  footerText String?
  updatedAt  DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id          String   @id @default(cuid())
  code        String   @unique // Trans ID from bank/gateway
  orderCode   String?
  amount      Float
  senderName  String?
  content     String?
  status      String   @default("COMPLETED")
  createdAt   DateTime @default(now())
}
