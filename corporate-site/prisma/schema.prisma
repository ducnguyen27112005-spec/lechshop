generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AdminUser {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String?
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PremiumProduct {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  thumbnail        String?
  shortDescription String?
  benefits         String?
  price            Float
  durationDays     Int
  isActive         Boolean  @default(true)
  isFeatured       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  relatedPosts     Post[]   @relation("PostRelatedProducts")
}

enum SocialPlatform {
  TIKTOK
  FACEBOOK
  INSTAGRAM
}

enum ServiceType {
  FOLLOW
  LIKE
  VIEW
}

model SocialCategory {
  id        String          @id @default(cuid())
  name      String
  slug      String          @unique
  iconKey   String?
  sortOrder Int             @default(0)
  isActive  Boolean         @default(true)
  services  SocialService[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model SocialService {
  id               String         @id @default(cuid())
  categoryId       String
  category         SocialCategory @relation(fields: [categoryId], references: [id])
  title            String
  slug             String         @unique
  shortDescription String?
  targetType       String // "video" | "profile" | "livestream" | "uid_or_link"
  unitLabel        String
  coverImageUrl    String?
  sortOrder        Int            @default(0)
  isActive         Boolean        @default(true)
  plans            SocialPlan[]
  orders           SocialOrder[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model SocialPlan {
  id           String        @id @default(cuid())
  serviceId    String
  service      SocialService @relation(fields: [serviceId], references: [id])
  code         String
  name         String
  pricePerUnit Float
  currency     String        @default("VND")
  min          Int
  max          Int
  tags         String? // CSV separated
  description  String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model SocialOrder {
  id           String         @id @default(cuid())
  code         String         @unique // SO-xxxx
  userId       String? // Optional for now if no auth enforcement
  platformSlug String
  serviceSlug  String
  serviceName  String
  service      SocialService? @relation(fields: [serviceSlug], references: [slug])

  targetUrl        String
  quantity         Int?
  selectedPlanCode String?
  unitPrice        Float?
  totalPrice       Float?
  customerNote     String?

  status String @default("received") // received | preparing | running | completed | need_info | cancelled

  system_status     String    @default("pending") // pending | running | completed | failed
  provider_status   String?   // raw status from provider API
  start_time        DateTime?
  completed_time    DateTime?
  expected_duration Int?      // duration in minutes

  events      SocialOrderEvent[]
  fulfillment SocialOrderFulfillment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([status, createdAt])
}

model SocialOrderEvent {
  id        String      @id @default(cuid())
  orderId   String
  order     SocialOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor     String // "admin" | "user" | "system"
  message   String
  createdAt DateTime    @default(now())
}

model SocialOrderFulfillment {
  id               String      @id @default(cuid())
  orderId          String      @unique
  order            SocialOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  providerName     String?
  providerOrderId  String?
  providerOrderUrl String?
  internalNote     String?
  etaAt            DateTime?
  updatedAt        DateTime    @updatedAt
}

enum OrderType {
  PREMIUM
  SOCIAL
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum FulfillStatus {
  NEW
  PROCESSING
  DONE
  CANCELLED
}

enum FulfillmentAction {
  DELIVER
  REPLACE
  NOTE
}

model Supplier {
  id        String             @id @default(cuid())
  name      String             @unique
  contact   String?
  note      String?
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  fulfillments  OrderFulfillment[]
  inventoryItems InventoryItem[]
}

model OrderFulfillment {
  id                   String            @id @default(cuid())
  orderId              String
  order                Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  supplierId           String?
  supplier             Supplier?         @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  supplierNameSnapshot String?
  batchCode            String?
  credentialText       String            // The account detail payload sent to customer
  action               FulfillmentAction @default(NOTE)
  note                 String?
  createdByAdminId     String?
  
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  @@index([orderId])
  @@index([supplierId])
  @@index([batchCode])
}

// ==========================================
// INVENTORY & ACCOUNT POOL
// ==========================================

enum InventoryStatus {
  AVAILABLE
  RESERVED
  SOLD
  REPLACED
  DISABLED
}

model InventoryItem {
  id              String          @id @default(cuid())
  productId       String          // e.g. 'netflix-premium'
  planId          String          // e.g. '1m'
  supplierId      String?         // source of this account
  supplier        Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  batchCode       String?         // to group imports
  credentialText  String          // email, pass, profile etc.
  status          InventoryStatus @default(AVAILABLE)
  
  // Tracking lifecycle
  reservedOrderId String?         // when assigned to an order but not yet delivered
  soldOrderId     String?         // when delivered
  
  // Trạng thái đền bù (Optionally useful)
  replacedByItemId String?        // if this account dies, what account replaced it?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([productId, planId, status])
  @@index([supplierId])
  @@index([status])
  @@index([reservedOrderId])
  @@index([soldOrderId])
}

model Order {
  id            String             @id @default(cuid())
  code          String             @unique
  customerName  String
  customerEmail String
  type          OrderType
  amount        Float
  paymentStatus PaymentStatus      @default(PENDING)
  fulfillStatus FulfillStatus      @default(NEW)
  adminNote     String?
  
  deliveredAt        DateTime?
  deliveredByAdminId String?
  
  fulfillments  OrderFulfillment[]

  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([createdAt])
  @@index([paymentStatus, fulfillStatus, createdAt])
}

enum PostStatus {
  DRAFT
  PUBLISHED
  HIDDEN
}

model Post {
  id           String     @id @default(cuid())
  title        String
  slug         String     @unique
  excerpt      String?
  content      String
  thumbnail    String?    // Original image link
  thumbnailUrl String?    // Processed/Resized image link
  status       PostStatus @default(DRAFT)
  viewCount    Int        @default(0)
  isFeatured   Boolean    @default(false)
  
  metaTitle       String?
  metaDescription String?
  ogImage         String?
  
  categoryId   String
  category     Category   @relation(fields: [categoryId], references: [id])
  tags         Tag[]      @relation("PostTags")
  relatedProducts PremiumProduct[] @relation("PostRelatedProducts")

  publishedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Category {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active | inactive
  posts     Post[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  posts     Post[]   @relation("PostTags")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Setting {
  id              String   @id @default("site-settings")
  hotline         String?
  email           String?
  address         String?
  socialLinks     Json?
  footerText      String?
  affiliateConfig Json? // Stores affiliate rules: defaultRate, holdDays, etc.
  updatedAt       DateTime @updatedAt
}

model Banner {
  id        String   @id @default(cuid())
  title     String?
  imageUrl  String
  link      String?
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TransactionStatus {
  pending
  matched
  reconciled
  failed
}

enum TransactionSource {
  bank_auto
  admin_manual
  affiliate
  refund
  payment_gateway
}

model Transaction {
  id                  String            @id @default(cuid())
  code                String            @unique // Trans ID from bank/gateway
  orderCode           String?
  amount              Float
  senderName          String?
  content             String?
  
  status              TransactionStatus @default(pending)
  source              TransactionSource @default(admin_manual)
  reconciledAt        DateTime?
  reconciledByAdminId String?
  mismatchAmount      Float?            // Số tiền lệch so với giá trị đơn hàng

  createdAt           DateTime          @default(now())

  @@index([status, createdAt])
  @@index([source])
}

model DiscountCode {
  id              String   @id @default(cuid())
  code            String   @unique
  type            String // "student" | "general"
  email           String? // chỉ dùng cho student
  discountPercent Int
  usageLimit      Int? // dùng cho general
  usedCount       Int      @default(0)
  used            Boolean  @default(false) // dùng cho student
  maxDiscountAmount Int?
  applyTo         String   @default("all") // "all" | "specific_products"
  isPublic        Boolean  @default(false)
  createdByAdminId String?
  productId       String?  // Gắn với 1 SP duy nhất cho loại student
  isActive        Boolean  @default(true)
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  usageLogs       CouponUsageLog[]
}

model CouponUsageLog {
  id             String       @id @default(cuid())
  discountCodeId String
  discountCode   DiscountCode @relation(fields: [discountCodeId], references: [id], onDelete: Cascade)
  userId         String?
  orderId        String?
  discountAmount Int
  ipAddress      String?
  usedAt         DateTime     @default(now())

  @@index([discountCodeId])
  @@index([orderId])
}

// ============================================
// AFFILIATE / REFERRAL SYSTEM
// ============================================

enum ReferralStatus {
  ACTIVE
  INACTIVE
  BANNED
}

enum CommissionStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

enum WithdrawStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

model ReferralCode {
  id        String         @id @default(cuid())
  userId    String         @unique // Reference to external user string ID
  code      String         @unique
  status    ReferralStatus @default(ACTIVE)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  clicks ReferralClick[]
}

model ReferralClick {
  id        String       @id @default(cuid())
  codeId    String
  code      ReferralCode @relation(fields: [codeId], references: [id], onDelete: Cascade)
  ipHash    String?
  userAgent String?
  createdAt DateTime     @default(now())
}

model ReferralAttribution {
  id             String   @id @default(cuid())
  referrerUserId String
  referredUserId String   @unique // The newly registered user ID
  createdAt      DateTime @default(now())
}

model Commission {
  id               String           @id @default(cuid())
  referrerUserId   String
  referredUserId   String
  orderId          String           @unique // Must link to a specific completed order
  baseAmount       Float // The total order amount
  ratePercent      Float // E.g., 10 for 10%
  commissionAmount Float // E.g., baseAmount * (ratePercent / 100)
  status           CommissionStatus @default(PENDING)
  holdUntil        DateTime? // Date until which this is held.
  approvedAt       DateTime?
  paidAt           DateTime?
  
  isSuspicious     Boolean          @default(false)
  suspiciousReason String?
  adminReason      String?
  
  logs             AffiliateLog[]

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model AffiliateLog {
  id                    String     @id @default(cuid())
  affiliateCommissionId String
  commission            Commission @relation(fields: [affiliateCommissionId], references: [id], onDelete: Cascade)
  action                String     // created / pending / approved / paid / rejected
  note                  String?
  adminId               String?
  createdAt             DateTime   @default(now())
}

model Wallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  balancePending   Float    @default(0)
  balanceAvailable Float    @default(0)
  balancePaidTotal Float    @default(0)
  updatedAt        DateTime @updatedAt
}

model WithdrawRequest {
  id          String         @id @default(cuid())
  userId      String
  amount      Float
  bankName    String
  bankAccount String
  bankOwner   String
  status      WithdrawStatus @default(PENDING)
  adminReason String? // Reason if rejected
  createdAt   DateTime       @default(now())
  processedAt DateTime?
}

// ============================================
// STUDENT VERIFICATION & DISCOUNTS
// ============================================

model StudentRequest {
  id         String   @id @default(cuid())
  fullName   String
  email      String   @unique
  studentId  String   @unique
  school     String
  status     String   @default("pending") // pending | approved | rejected
  adminNote  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model StudentBenefit {
  id               String   @id @default(cuid())
  email            String
  productId        String   // slug or ID config
  lastEndAt        DateTime?
  nextEligibleAt   DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([email, productId])
}

model StudentDiscountConfig {
  id               String   @id @default(cuid())
  productId        String   @unique
  discountPercent  Int      @default(15) // MAX: 20%
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
